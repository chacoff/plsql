		<parameter name="BEWNR" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT 

    RP.CHARGE,
    RP.NUANCE,
    RP.MIX,
    RP.MITTRAILT,
    RP.PNEUST,
    RP.ENERGIEEAFMWH,
    RP.ENERGIETOTEAFMWH,
    RP.OXEAFM3,
    RP.ENERGIELFKWH,
    RP.CAOEAFT,
    RP.CAOSPATHLFT,
    RP.FERROCARBT,
    RP.NUMPOCHE,
    RP.TTT,
    RP.POWEROFF,
    RP.POWERON,
    RP.POIDST,
    RP.RESTET,
    RP.NBDEMIPRODAD1,
    RP.NBDEMIPRODAB2,
    RP.NBDEMIPRODAB3,
    RP.NBDEMIPRODAB4,
    RP.PRODAD1T,
    RP.PRODAB2T,
    RP.PRODAB3T,
    RP.PRODAB4T,
    RP.PRODHD1T,
    RP.PRODHB2T,
    RP.PRODHB3T,
    RP.PRODHB4T,
    RP.PRODTOTT
    
FROM R_PRODUCTIONJOURNAL RP 
WHERE RP.ID = $P{BEWNR}  

/*
--remplacer le paramètre par $P----{BEWNR} 
*/]]>
		</queryString>
