	<queryString language="SQL">
		<![CDATA[SELECT 
    RP.CHARGE,
    RP.NUANCE,
    RP.MIX,
    RP.MITTRAILT,
    RP.PNEUST,
    RP.ENERGIEEAFMWH,
    RP.ENERGIETOTEAFMWH,
    RP.OXEAFM3,
    RP.ENERGIELFKWH,
    RP.CAOEAFT,
    RP.CAOSPATHLFT,
    RP.FERROCARBT,
    RP.NUMPOCHE,
    RP.TTT,
    RP.POWEROFF,
    RP.POWERON,
    RP.POIDST,
    RP.RESTET,
    RP.NBDEMIPRODAD1,
    RP.NBDEMIPRODAB2,
    RP.NBDEMIPRODAB3,
