	<subDataset name="R_SUMPROD" uuid="b1975582-9519-4264-a009-fdb50cfac5be">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="OCI"/>
		<parameter name="BEWNR" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT 
  COUNT(PR.CHARGE),
  NULL,
  NULL,
  PH.SUMMITTRAILT,
  PH.SUMPNEUST,
  PH.SUMENERGIEEAFMWH,
  PH.SUMENERGIETOTEAFMWH,
  PH.SUMOXEAFM3,
  PH.SUMENERGIELFKWH,
  PH.SUMCAOEAFT,
  PH.SUMCAOSPATHLFT,
  PH.SUMFERROCARBT,
  NULL,
  PH.SUMTTT,
  PH.SUMPOWEROFF,
  PH.SUMPOWERON,
  PH.SUMPOIDST,
  PH.SUMRESTET,
  PH.SUMNBDEMIPRODAD1,
  PH.SUMNBDEMIPRODAB2,
  PH.SUMNBDEMIPRODAB3,
  PH.SUMNBDEMIPRODAB4,
  PH.SUMPRODAD1T,
  PH.SUMPRODAB2T,
  PH.SUMPRODAB3T,
  PH.SUMPRODAB4T,
  PH.SUMPRODHD1T,
  PH.SUMPRODHB2T,
  PH.SUMPRODHB3T,
  PH.SUMPRODHB4T,
  PH.SUMPRODTOTT
FROM R_ProductionJournalHead PH
JOIN R_ProductionJournal PR ON PR.ID = PH.ID
WHERE PH.ID = $P{BEWNR}

/*
--remplacer le paramètre par $P----{BEWNR} 
*/

GROUP BY 
  PH.SUMMITTRAILT,
  PH.SUMPNEUST,
  PH.SUMENERGIEEAFMWH,
  PH.SUMENERGIETOTEAFMWH,
  PH.SUMOXEAFM3,
  PH.SUMENERGIELFKWH,
  PH.SUMCAOEAFT,
  PH.SUMCAOSPATHLFT,
  PH.SUMFERROCARBT,
  PH.SUMTTT,
  PH.SUMPOWEROFF,
  PH.SUMPOWERON,
  PH.SUMPOIDST,
  PH.SUMRESTET,
  PH.SUMNBDEMIPRODAD1,
  PH.SUMNBDEMIPRODAB2,
  PH.SUMNBDEMIPRODAB3,
  PH.SUMNBDEMIPRODAB4,
  PH.SUMPRODAD1T,
  PH.SUMPRODAB2T,
  PH.SUMPRODAB3T,
  PH.SUMPRODAB4T,
  PH.SUMPRODHD1T,
  PH.SUMPRODHB2T,
  PH.SUMPRODHB3T,
  PH.SUMPRODHB4T,
  PH.SUMPRODTOTT]]>
		</queryString>
