		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="PSI522ACEBP1"/>
		<parameter name="BEWNR" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT 
    DTBEGINN,
    DURATIONSTR,
    SHIFT,
    HEATNO,
    CODEARRET,
    TEXT,
    REMARK
FROM R_ProductionJournalDT
WHERE Anlage LIKE '%EAF%'
  AND ID = $P{BEWNR}
  UNION ALL

SELECT 
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL

FROM DUAL
WHERE NOT EXISTS (
    SELECT 1 FROM R_ProductionJournalDT 
    WHERE Anlage LIKE '%EAF%' AND ID = $P{BEWNR}
)]]>
		</queryString>
