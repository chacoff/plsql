	</subDataset>
	<parameter name="PARAMETER01" class="java.lang.Integer"/>
	<queryString language="SQL">
		<![CDATA[SELECT

	DTBEGINN,
	DURATIONSTR,
	SHIFT,
	HEATNO,
	CODEARRET,
	TEXT,
	REMARK

