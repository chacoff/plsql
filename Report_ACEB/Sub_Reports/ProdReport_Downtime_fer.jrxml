	<subDataset name="R_DATEPROD" uuid="c318e10f-a855-490d-908a-c2c590a56ec6">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="DataAdapter.jrdax"/>
		<parameter name="BEWNR" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT TO_CHAR(DTPROD, 'DD/MM/YYYY') AS DateProduction
FROM R_ProductionJournalHead
WHERE ID = $P{BEWNR}]]>
		</queryString>
		<field name="DATEPRODUCTION" class="java.lang.String">
