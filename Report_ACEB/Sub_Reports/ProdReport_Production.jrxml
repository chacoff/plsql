	<subDataset name="R_PROD" uuid="8b841015-ca01-45db-8821-33afa27ae66c">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="PSI522ACEBP1"/>
		<parameter name="BEWNR" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT 
    CHARGE,
    NUANCE,
    MIX,
    MITTRAILT,
    PNEUST,
    ENERGIEEAFMWH,
    ENERGIETOTEAFMWH,
    OXEAFM3,
    ENERGIELFKWH,
    CAOEAFT,
    CAOSPATHLFT,
    FERROCARBT,
    NUMPOCHE,
    TTT,
    POWEROFF,
    POWERON,
    POIDST,
    RESTET,
    NBDEMIPRODAD1,
    NBDEMIPRODAB2,
    NBDEMIPRODAB3,
    NBDEMIPRODAB4,
    PRODAD1T,
    PRODAB2T,
    PRODAB3T,
    PRODAB4T,
    PRODHD1T,
    PRODHB2T,
    PRODHB3T,
    PRODHB4T,
    PRODTOTT,
    NB_BASKET,
    HBI_CONSUMPTION,
    H2_CONSUMPTION,
    FINAL_TEMPERATURE_VD,
    VD_DURATION,
	NBDEMIPRODAD2,
	NBDEMIPRODAD4,
	NBDEMIPRODAB5,
	PRODAD2T,
	PRODAD4T,
	PRODAB5T,
	PRODHD2T,
	PRODHD4T,
	PRODHB5T
   
FROM R_PRODUCTIONJOURNAL
WHERE ID = $P{BEWNR}

UNION ALL

SELECT 
    '#', NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL,
    NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL,
    NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL,
    NULL,NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, 
    NULL, NULL, NULL, NULL, NULL
    
FROM DUAL
WHERE NOT EXISTS (
    SELECT 1 FROM R_PRODUCTIONJOURNAL WHERE ID = $P{BEWNR}
)]]>
		</queryString>
