	<subDataset name="R_SUMPROD" uuid="b1975582-9519-4264-a009-fdb50cfac5be">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="PSI522ACEBP1"/>
		<parameter name="BEWNR" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT 
  PH.SUMCHARGE,
  PH.SUMMITTRAILT,
  PH.SUMPNEUST,
  PH.SUMENERGIEEAFMWH,
  PH.SUMENERGIETOTEAFMWH,
  PH.SUMOXEAFM3,
  PH.SUMENERGIELFKWH,
  PH.SUMCAOEAFT,
  PH.SUMCAOSPATHLFT,
  PH.SUMFERROCARBT,
  PH.SUMTTT,
  PH.SUMPOWEROFF,
  PH.SUMPOWERON,
  PH.SUMPOIDST,
  PH.SUMRESTET,
  PH.SUMNBDEMIPRODAD1,
  PH.SUMNBDEMIPRODAB2,
  PH.SUMNBDEMIPRODAB3,
  PH.SUMNBDEMIPRODAB4,
  PH.SUMPRODAD1T,
  PH.SUMPRODAB2T,
  PH.SUMPRODAB3T,
  PH.SUMPRODAB4T,
  PH.SUMPRODHD1T,
  PH.SUMPRODHB2T,
  PH.SUMPRODHB3T,
  PH.SUMPRODHB4T,
  PH.SUMPRODTOTT,
  PH.SUM_NB_BASKET,
  PH.SUM_HBI_CONSUMPTION,
  PH.SUM_H2_CONSUMPTION,
  PH.SUM_VD_DURATION,
  PH.SUMNBDEMIPRODAD2,
  PH.SUMNBDEMIPRODAD4,
  PH.SUMNBDEMIPRODAB5,
  PH.SUMPRODAD2T,
  PH.SUMPRODAD4T,
  PH.SUMPRODAB5T,
  PH.SUMPRODHD2T,
  PH.SUMPRODHD4T,
  PH.SUMPRODHB5T
  
FROM R_ProductionJournalHead PH
WHERE PH.ID = $P{BEWNR}

UNION ALL

-- Ligne vide si aucune donnée trouvée
SELECT 
  NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL,
  NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL,
  NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL,
  NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL
  
FROM DUAL
WHERE NOT EXISTS (
  SELECT 1
  FROM R_ProductionJournalHead PH
  WHERE PH.ID = $P{BEWNR}
)]]>
