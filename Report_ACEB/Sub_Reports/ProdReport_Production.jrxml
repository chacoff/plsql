	<subDataset name="R_DATEPROD" uuid="07094792-dca1-4de3-b0ff-411bafa1b5b1">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="PSI522ACEBP1"/>
		<parameter name="BEWNR" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT TO_CHAR(DTPROD, 'DD/MM/YYYY') AS DateProduction
FROM R_ProductionJournalHead
WHERE ID = $P{BEWNR}


/*
--remplacer le paramètre par $P----{BEWNR} 
*/]]>
		</queryString>
		<field name="DATEPRODUCTION" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="DATEPRODUCTION"/>
			<property name="com.jaspersoft.studio.field.label" value="DATEPRODUCTION"/>
		</field>
	</subDataset>
	<parameter name="PARAMETER01" class="java.lang.Integer" isForPrompting="false"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
    RP.CHARGE,
    RP.NUANCE,
    RP.MIX,
    RP.MITTRAILT,
    RP.PNEUST,
    RP.ENERGIEEAFMWH,
    RP.ENERGIETOTEAFMWH,
    RP.OXEAFM3,
    RP.ENERGIELFKWH,
    RP.CAOEAFT,
    RP.CAOSPATHLFT,
    RP.FERROCARBT,
    RP.NUMPOCHE,
    RP.TTT,
    RP.POWEROFF,
    RP.POWERON,
    RP.POIDST,
    RP.RESTET,
    RP.NBDEMIPRODAD1,
    RP.NBDEMIPRODAB2,
    RP.NBDEMIPRODAB3,
    RP.NBDEMIPRODAB4,
    RP.PRODAD1T,
    RP.PRODAB2T,
    RP.PRODAB3T,
    RP.PRODAB4T,
    RP.PRODHD1T,
    RP.PRODHB2T,
    RP.PRODHB3T,
    RP.PRODHB4T,
    RP.PRODTOTT,
    RH.DTPROD

FROM R_PRODUCTIONJOURNAL RP, R_ProductionJournalHead RH
WHERE RP.ID = $P{PARAMETER01}
 AND RP.ID = RH.ID


/*
--remplacer le paramètre par $P----{BEWNR} 
*/]]>
	</queryString>
