		<parameter name="BEWNR" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT 

  PH.CONMITTRAILT,
  PH.CONPNEUST,
  PH.CONENERGIEEAFMWH,
  PH.CONENERGIETOTEAFMWH,
  PH.CONOXEAFM3,
  PH.CONENERGIELFKWH,
  PH.CONCAOEAFT,
  PH.CONCAOSPATHLFT,
  PH.CONFERROCARBT,
  PH.CONTTT,
  PH.CONPOWEROFF,
  PH.CONPOWERON,
  PH.CONPOIDST,
  PH.CONRESTET,
  PH.CONNBDEMIPRODAD1,
  PH.CONNBDEMIPRODAB2,
  PH.CONNBDEMIPRODAB3,
  PH.CONNBDEMIPRODAB4,
  PH.CONPRODAD1T,
  PH.CONPRODAB2T,
  PH.CONPRODAB3T,
  PH.CONPRODAB4T,
  PH.CONPRODHD1T,
  PH.CONPRODHB2T,
  PH.CONPRODHB3T,
  PH.CONPRODHB4T,
  PH.CONPRODTOTT,
  PH.CON_HBI_CONSUMPTION,
  PH.CON_H2_CONSUMPTION,
  PH.CON_VD_DURATION,
  PH.CONNBDEMIPRODAD2,
  PH.CONNBDEMIPRODAD4,
  PH.CONNBDEMIPRODAB5,
  PH.CONPRODAD2T,
  PH.CONPRODAD4T,
  PH.CONPRODAB5T,
  PH.CONPRODHD2T,
  PH.CONPRODHD4T,
  PH.CONPRODHB5T
  
  
FROM R_ProductionJournalHead PH
WHERE PH.ID = $P{BEWNR}

UNION ALL

-- Ligne vide si aucune donnée trouvée
SELECT 
  NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL,
  NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL,
  NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL,
  NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL
  
FROM DUAL
WHERE NOT EXISTS (
  SELECT 1
  FROM R_ProductionJournalHead PH
  WHERE PH.ID = $P{BEWNR}
)]]>
		</queryString>
